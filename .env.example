# Context Graph Engine configuration
#
# The engine runs FULLY LOCALLY by default — no keys required:
#   • Embeddings run in-process (transformers.js), model cached on first use.
#   • Extraction uses a local Ollama model (install: https://ollama.com).
# Set the cloud keys below only if you want higher-quality cloud models; they
# are picked up automatically when present.

# --- Cloud (optional) ---------------------------------------------------------
# Entity/relationship extraction on Claude (Anthropic).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the extraction model (default: claude-haiku-4-5-20251001)
# CONTEXT_GRAPH_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Embeddings on OpenAI (Anthropic has no embeddings endpoint).
# OPENAI_API_KEY=sk-...
# Optional: override the embedding model (default: text-embedding-3-small)
# CONTEXT_GRAPH_EMBEDDING_MODEL=text-embedding-3-small

# --- Local (defaults; used when the keys above are absent) --------------------
# Force local even when cloud keys are set.
# CONTEXT_GRAPH_LOCAL=1
# In-process embedding model (default: Xenova/all-MiniLM-L6-v2)
# CONTEXT_GRAPH_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Local extraction via Ollama (default model: llama3.2)
# CONTEXT_GRAPH_OLLAMA_MODEL=llama3.2
# CONTEXT_GRAPH_OLLAMA_URL=http://localhost:11434

# --- Storage ------------------------------------------------------------------
# Where the graph database lives (default: ./.context-graph/graph.db)
# CONTEXT_GRAPH_DB=./.context-graph/graph.db
