# Context Graph Engine — configuration
#
# Runs fully locally by default (no keys): extraction and summaries use a local
# Ollama model. Install Ollama (https://ollama.com) and pull a model:
#   ollama pull llama3.2
#
# Set an OpenRouter key for higher-quality cloud summaries/extraction — it's
# picked up automatically when present.

# --- Cloud (optional) ---------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-...
# Optional: override the model (default: openai/gpt-4o-mini)
# CONTEXT_GRAPH_OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: override the API base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Local (defaults; used when the key above is absent) ----------------------
# Force local even when a cloud key is set.
# CONTEXT_GRAPH_LOCAL=1
# CONTEXT_GRAPH_OLLAMA_MODEL=llama3.2
# CONTEXT_GRAPH_OLLAMA_URL=http://localhost:11434

# --- Graph location -----------------------------------------------------------
# Where the graph lives (default: <repo>/.context)
# CONTEXT_GRAPH_DIR=.context
